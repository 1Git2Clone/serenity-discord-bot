# DB
DB_USER="not-so-top-secret-username"
DB_PASSWORD="very-top-secret-password"
DB_NAME="bot_database" # <- Can be whatever, so long as it's a valid database name.
DB_NETWORK="127.0.0.1" # <- Keep as localhost if you don't have it externally or don't user docker.
DB_PORT=5432           # <- Default for PostgreSQL.

DATABASE_URL="postgres://${DB_USER}:${DB_PASSWORD}@${DB_NETWORK}:${DB_PORT}/${DB_NAME}"

# AI (Optional) — the provider is chosen at build time via the `ai-<backend>` Cargo feature.
AI_MODEL="deepseek-chat" # <- Model name for the chosen backend.
AI_API_KEY=""            # <- Required for hosted backends (deepseek/openai/anthropic/google/groq).
# AI_MAX_MSG_CONTEXT=10  # <- Recent messages sent as context (capped at 100). Defaults to 10.
# AI_CHAT_ENDPOINT=""    # <- Only for `ai-ollama`, to override http://127.0.0.1:11434.

# Token
BOT_TOKEN="very-top-secret-token" # <- Check: `https://discord.com/developers/applications`.
