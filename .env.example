# DB
DB_USER="not-so-top-secret-username"
DB_PASSWORD="very-top-secret-password"
DB_NAME="bot_database" # <- Can be whatever, so long as it's a valid database name.
DB_NETWORK="127.0.0.1" # <- Keep as localhost if you don't have it externally or don't user docker.
DB_PORT=5432           # <- Default for PostgreSQL.

DATABASE_URL="postgres://${DB_USER}:${DB_PASSWORD}@${DB_NETWORK}:${DB_PORT}/${DB_NAME}"

# AI (Optional) — the provider is chosen at build time via the `ai-<backend>` Cargo feature.
AI_MODEL="deepseek-chat" # <- Model name for the chosen backend. /ai-review needs one with function calling (deepseek-chat has it).
AI_API_KEY=""            # <- Required for hosted backends (deepseek/openai/anthropic/google/groq).
# AI_MAX_MSG_CONTEXT=10  # <- Recent messages sent as context (capped at 100). Defaults to 10.
# AI_CHAT_ENDPOINT=""    # <- Only for `ai-ollama`, to override http://127.0.0.1:11434.
# REDIS_URL="redis://127.0.0.1:6379" # <- Optional: caches context to avoid Discord fetches. Falls back to Discord if unset.

# AI code review (Optional) — required only to use `/ai-review`. Also needs `git` and `gh` (GitHub CLI) on the host.
# Per-server access is managed in Discord: an administrator runs `/ai-review enable` (or `disable`).
# GITHUB_OAUTH_CLIENT_ID=""        # <- GitHub App client ID (Iv prefix). Enable Device Flow in app settings; no client secret needed.
# GITHUB_APP_ID=""                 # <- GitHub App ID (numeric). Shown at the top of the app settings page.
# GITHUB_APP_PRIVATE_KEY_PATH=""   # <- Path to the GitHub App private key .pem file. Generate in the app's "Private keys" section.
# GITHUB_OAUTH_SCOPE="public_repo" # <- Set to `repo` to allow private-repo reviews.
# GITHUB_TOKEN_TTL_SECS=3600       # <- How long a user's GitHub authorization is cached in memory.
# AI_REVIEW_MAX_ITERATIONS=20      # <- Max agent tool-call rounds per review. Defaults to 20.
# AI_REVIEW_TIMEOUT_SECS=600       # <- Wall-clock limit for a single review. Defaults to 600.

# Token
BOT_TOKEN="very-top-secret-token" # <- Check: `https://discord.com/developers/applications`.
