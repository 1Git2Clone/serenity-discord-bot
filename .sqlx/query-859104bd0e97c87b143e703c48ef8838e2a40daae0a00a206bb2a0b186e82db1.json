  "query": "SELECT remind_at, finished_at, message\n           FROM reminders\n           WHERE user_id = $1\n             AND ($2::bool OR (finished_at IS NULL) = $3::bool)\n             AND ($4::text IS NULL OR message ILIKE $4 ESCAPE '\\')\n           ORDER BY (finished_at IS NULL) DESC, COALESCE(finished_at, remind_at)",
